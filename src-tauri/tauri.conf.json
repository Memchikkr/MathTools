{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MathTools",
  "version": "0.1.0",
  "identifier": "com.mathtools.desktop",
  "build": {
    "frontendDist": "../frontend/build",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd frontend && npm start",
    "beforeBuildCommand": "cd frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MathTools",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "devtools": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "externalBin": [
      "math-tools-backend"
    ],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}